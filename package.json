{
	"name": "mc-scrpt-live",
	"author": "@cowglow",
	"version": "0.1.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev --port 3000 --host",
		"dev:docker": "docker compose run --service-ports svelte-kit bash",
		"build": "vite build",
		"preview": "vite preview",
		"check": "svelte-check --t,config ./tsconfig.json && tsc -p tsconfig.node.json",
		"test": "vitest --watch",
		"format": "prettier --plugin-search-dir . --write .",
		"lint": "prettier --check . && eslint .",
		"clean": "rm -r ./build ./.svelte-kit",
		"sync": "npx tsx --env-file=.env ./scripts/sync-events.ts",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build"
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.9",
		"@sveltejs/kit": "^2.53.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"@types/eslint": "^9.6.0",
		"@types/node": "^24.3.0",
		"dotenv": "^17.2.3",
		"eslint": "^9.38.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.12.5",
		"globals": "^16.3.0",
		"node-fetch": "^3.3.2",
		"prettier": "^3.3.2",
		"prettier-plugin-svelte": "^3.2.6",
		"svelte": "^5.53.5",
		"svelte-check": "^4.4.3",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1",
		"vite": "^7.3.1",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.0.18",
		"storybook": "^10.2.12",
		"@storybook/sveltekit": "^10.2.12",
		"@storybook/addon-svelte-csf": "^5.0.11",
		"@chromatic-com/storybook": "^5.0.1",
		"@storybook/addon-vitest": "^10.2.12",
		"@storybook/addon-a11y": "^10.2.12",
		"@storybook/addon-docs": "^10.2.12",
		"eslint-plugin-storybook": "^10.2.12",
		"playwright": "^1.58.2",
		"@vitest/browser-playwright": "^4.0.18",
		"@vitest/coverage-v8": "^4.0.18"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/cowglow/mc-scrpt-live.git"
	}
}
